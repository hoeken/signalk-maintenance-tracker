{
  "name": "signalk-maintenance-tracker-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Dev-only tooling for the buildless webapp in ../public (type-checking, tests, vendoring). Produces no runtime artifact.",
  "scripts": {
    "typecheck": "tsc --noEmit -p .",
    "test": "vitest run",
    "vendor": "node scripts/vendor.mjs"
  },
  "devDependencies": {
    "@preact/signals": "2.0.4",
    "@testing-library/preact": "^3.2.4",
    "bootstrap-icons": "1.13.1",
    "dayjs": "1.11.13",
    "htm": "3.1.1",
    "jsdom": "^25.0.1",
    "preact": "10.26.9",
    "snarkdown": "2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
