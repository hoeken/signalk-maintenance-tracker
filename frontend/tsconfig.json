{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "preact": ["./node_modules/preact/src/index.d.ts"],
      "preact/hooks": ["./node_modules/preact/hooks/src/index.d.ts"],
      "@preact/signals": ["./node_modules/@preact/signals/dist/signals.d.ts"],
      "@preact/signals-core": ["./node_modules/@preact/signals-core/dist/signals-core.d.ts"],
      "htm": ["./node_modules/htm/dist/htm.d.ts"],
      "dayjs": ["./node_modules/dayjs/index.d.ts"]
    }
  },
  "include": ["types/**/*.d.ts", "../public/app/**/*.js"]
}
