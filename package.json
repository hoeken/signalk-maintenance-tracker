{
  "name": "signalk-maintenance-tracker",
  "version": "1.0.0",
  "description": "Track recurring boat maintenance tasks with runtime and calendar based intervals.",
  "main": "dist/index.js",
  "license": "MIT",
  "author": "Zach Hoeken <hoeken@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/hoeken/signalk-maintenance-tracker"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-utility",
    "signalk",
    "maintenance",
    "boat"
  ],
  "scripts": {
    "build": "tsc",
    "watch:backend": "tsc -w",
    "typecheck:frontend": "npm --prefix frontend run typecheck",
    "test:backend": "vitest run",
    "test:frontend": "npm --prefix frontend run test",
    "test": "npm run test:backend && npm run test:frontend",
    "icons": "npm --prefix frontend run icons",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "eslint --fix . && prettier --write .",
    "format:check": "eslint . && prettier --check .",
    "prepublishOnly": "npm run build",
    "release": "git tag -d v$npm_package_version; git tag v$npm_package_version && git push && git push origin v$npm_package_version",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,html,md,yml,yaml}": "prettier --write"
  },
  "signalk": {
    "displayName": "Maintenance Tracker",
    "appIcon": "icons/icon-192.png",
    "screenshots": [
      "./docs/screenshots/homepage.png",
      "./docs/screenshots/dark-mode.png",
      "./docs/screenshots/task-detail.png",
      "./docs/screenshots/edit-task.png",
      "./docs/screenshots/completed.png",
      "./docs/screenshots/main-log.png"
    ]
  },
  "files": [
    "dist/",
    "public/",
    "docs/screenshots/",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "express": "^4.19.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "supertest": "^7.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.0.0"
  }
}
